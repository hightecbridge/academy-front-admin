# 복사 후 .env.local 등으로 두고 쓰면 됩니다 (비밀값 없음 — 커밋 가능한 예시)
#
# 로컬: 로컬 API 서버 (Vite proxy)
# VITE_API_BASE_URL=/api/academy
#
# 운영: 원격 API (어드민 SPA는 admin.hiacademy.co.kr 등 별도 도메인 가능)
# VITE_API_BASE_URL=https://api.dbridgehub.com/api/academy
#
# API 개별 연동 등 (예: 빌링/백엔드 연계 시) — test_ck_...
# VITE_TOSS_PAYMENTS_CLIENT_KEY=test_ck_your_key_here
#
# 포인트 충전(결제위젯 SDK) 전용 — 반드시 위젯 연동 클라이언트 키 test_gck_...
# API 개별 키(test_ck_)는 결제위젯에서 사용할 수 없습니다.
# VITE_TOSS_PAYMENTS_WIDGET_CLIENT_KEY=test_gck_your_widget_key_here
